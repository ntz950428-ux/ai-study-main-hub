// ===== TASBIH =====
let tasbihCount=0,tasbihMax=33,tasbihZikr='سُبْحَانَ اللهِ',tasbihBn='সুবহানাল্লাহ';
function setTasbihMode(max,btn,zikr,bn){
  tasbihMax=max;tasbihZikr=zikr;tasbihBn=bn;
  document.querySelectorAll('.tmode-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tasbih-zikr').textContent=zikr;
  document.getElementById('tasbih-total').textContent='/ '+max;
  document.getElementById('tasbih-bn-label').textContent=bn;
  resetTasbih();
}
function tapTasbih(){
  if(tasbihCount>=tasbihMax){resetTasbih();return;}
  tasbihCount++;
  document.getElementById('tasbih-count').textContent=tasbihCount;
  document.getElementById('tasbih-bar').style.width=(tasbihCount/tasbihMax*100)+'%';
