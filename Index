// ===== PRAYER =====
const pIds=['fajr','dhuhr','asr','maghrib','isha'];
const pKeys=['Fajr','Dhuhr','Asr','Maghrib','Isha'];
let lastLat=23.8103,lastLon=90.4125;

async function fetchPrayerTimes(lat,lon,locName){
  document.getElementById('prayer-loading').style.display='block';
  document.getElementById('loc-btn').style.display='none';
  try{
    const now=new Date();
    const url=`https://api.aladhan.com/v1/timings/${now.getDate()}-${now.getMonth()+1}-${now.getFullYear()}?latitude=${lat}&longitude=${lon}&method=1`;
    const res=await fetch(url);
    if(!res.ok)throw new Error();
    const data=await res.json();
    const t=data.data.timings;
    pKeys.forEach((k,i)=>document.getElementById('t-'+pIds[i]).textContent=fmt12(t[k]));
    document.getElementById('location-text').textContent='📍 '+locName;
    highlightNext(t); lastLat=lat; lastLon=lon;
  }catch(e){alert('নামাজের সময়সূচি লোড হয়নি। ইন্টারনেট কানেকশন চেক করুন।');}
  document.getElementById('prayer-loading').style.display='none';
  document.getElementById('loc-btn').style.display='block';
  document.getElementById('loc-btn').textContent='🔄 লোকেশন পরিবর্তন করো';
}

function getLocation(){
  if(!navigator.geolocation){fetchPrayerTimes(23.8103,90.4125,'ঢাকা, বাংলাদেশ');return;}
  document.getElementById('prayer-loading').style.display='block';
  document.getElementById('loc-btn').style.display='none';
  navigator.geolocation.getCurrentPosition(
    async pos=>{
      const{latitude:lat,longitude:lon}=pos.coords;
      let name='আপনার এলাকা';
      try{const r=await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lon}&format=json&accept-language=bn`);const d=await r.json();name=d.address.city||d.address.town||d.address.county||d.address.state||name;}catch(e){}
      fetchPrayerTimes(lat,lon,name);
    },
    err=>{
      document.getElementById('prayer-loading').style.display='none';
      document.getElementById('loc-btn').style.display='block';
      let m='লোকেশন পাওয়া যায়নি। ';
      if(err.code===1)m+='ব্রাউজারে লোকেশন পারমিশন দিন।';
      else m+='ঢাকার সময়সূচি দেখানো হচ্ছে।';
      alert(m);
      fetchPrayerTimes(23.8103,90.4125,'ঢাকা, বাংলাদেশ');
    },
    {timeout:10000,enableHighAccuracy:true}
  );
}

function fmt12(t){const[h,m]=t.split(':').map(Number);return`${h%12||12}:${String(m).padStart(2,'0')} ${h>=12?'PM':'AM'}`;}
function highlightNext(t){
  const cur=new Date().getHours()*60+new Date().getMinutes();
  let ni=-1;
  pKeys.forEach((k,i)=>{const[h,m]=t[k].split(':').map(Number);if(ni===-1&&h*60+m>cur)ni=i;});
  pIds.forEach((id,i)=>document.getElementById('card-'+id).classList.toggle('next',i===ni));
}
fetchPrayerTimes(23.8103,90.4125,'ঢাকা, বাংলাদেশ');

// ===== QURAN =====
const surahs=[
  {num:1,ar:'الفاتحة',bn:'আল-ফাতিহা',ayahs:7,type:'মাক্কী'},
  {num:2,ar:'البقرة',bn:'আল-বাকারা',ayahs:286,type:'মাদানী'},
  {num:3,ar:'آل عمران',bn:'আলে ইমরান',ayahs:200,type:'মাদানী'},
  {num:4,ar:'النساء',bn:'আন-নিসা',ayahs:176,type:'মাদানী'},
  {num:5,ar:'المائدة',bn:'আল-মায়েদা',ayahs:120,type:'মাদানী'},
  {num:18,ar:'الكهف',bn:'আল-কাহফ',ayahs:110,type:'মাক্কী'},
  {num:36,ar:'يس',bn:'ইয়াসীন',ayahs:83,type:'মাক্কী'},
  {num:55,ar:'الرحمن',bn:'আর-রহমান',ayahs:78,type:'মাদানী'},
  {num:67,ar:'الملك',bn:'আল-মুলক',ayahs:30,type:'মাক্কী'},
  {num:112,ar:'الإخلاص',bn:'আল-ইখলাস',ayahs:4,type:'মাক্কী'},
  {num:113,ar:'الفلق',bn:'আল-ফালাক',ayahs:5,type:'মাক্কী'},
  {num:114,ar:'الناس',bn:'আন-নাস',ayahs:6,type:'মাক্কী'},
];
let filteredSurahs=[...surahs],curSurahNum=1,surahPlaying=false;

function renderSurahList(){
  document.getElementById('surah-list').innerHTML=filteredSurahs.map(s=>`
    <div class="surah-item" onclick="openSurah(${s.num})">
      <div class="snum">${s.num}</div>
      <div class="sinfo"><div class="sbn">${s.bn}</div><div class="smeta">${s.ayahs} আয়াত · ${s.type}</div></div>
      <div class="sar">${s.ar}</div>
    </div>`).join('');
}
function filterSurahs(){const q=document.getElementById('surah-search').value.toLowerCase();filteredSurahs=surahs.filter(s=>s.bn.toLowerCase().includes(q)||s.ar.includes(q));renderSurahList();}

async function openSurah(num){
  stopAllAudio();curSurahNum=num;
  document.getElementById('surah-list-view').style.display='none';
  document.getElementById('quran-reader').classList.add('active');
  const s=surahs.find(x=>x.num===num);
  document.getElementById('reader-surah-name').textContent=s.bn;
  document.getElementById('reader-surah-ar').textContent=s.ar;
  document.getElementById('audio-title').textContent=s.bn+' — তেলাওয়াত';
  document.getElementById('ayah-list').innerHTML='<div class="loading"><div class="spinner"></div>আয়াত লোড হচ্ছে...</div>';
  try{
    const[ar,bn]=await Promise.all([
      fetch(`https://api.alquran.cloud/v1/surah/${num}`).then(r=>r.json()),
      fetch(`https://api.alquran.cloud/v1/surah/${num}/bn.bengali`).then(r=>r.json())
    ]);
    const aA=ar.data.ayahs,bA=bn.data.ayahs;
    document.getElementById('ayah-list').innerHTML=aA.map((a,i)=>`
      <div class="ayah-card">
        <div class="ayah-ar">${a.text}</div>
        <div class="ayah-bn">${bA[i]?.text||''}</div>
        <div class="ayah-foot">
          <span class="ayah-num">আয়াত ${a.numberInSurah}</span>
          <button class="ayah-abtn" id="aybtn-${a.numberInSurah}" onclick="playAyah(${num},${a.numberInSurah},${a.number})">▶ শুনুন</button>
        </div>
      </div>`).join('');
  }catch(e){document.getElementById('ayah-list').innerHTML='<div class="loading">লোড হয়নি। ইন্টারনেট চেক করুন।</div>';}
}
function backToList(){stopAllAudio();document.getElementById('surah-list-view').style.display='block';document.getElementById('quran-reader').classList.remove('active');}

// AUDIO — quranicaudio.com (most reliable, public domain)
function getSurahAudioUrl(surahNum,reciterId){
  const pad=String(surahNum).padStart(3,'0');
  const urls={
    '7':`https://download.quranicaudio.com/quran/mishaari_raashid_al_3afaasee/${pad}.mp3`,
    '1':`https://download.quranicaudio.com/quran/abdul_basit_murattal/${pad}.mp3`,
    '3':`https://download.quranicaudio.com/quran/abu_bakr_al-shatri/${pad}.mp3`,
  };
  return urls[reciterId]||urls['7'];
}
function getAyahAudioUrl(globalNum,reciterId){
  // everyayah.com has per-ayah files reliably
  const pad=String(globalNum).padStart(6,'0');
  const reciters={
    '7':'Mishari_Rashid_Alafasy',
    '1':'Abdul_Basit_Murattal_64kbps',
    '3':'Abu_Bakr_al-Shatri_192kbps',
  };
  const r=reciters[reciterId]||reciters['7'];
  return`https://everyayah.com/data/${r}/${pad}.mp3`;
}

function showAudioError(btn){
  const orig=btn.textContent;
  btn.textContent='❌ লোড হয়নি';
  btn.style.color='red';
  setTimeout(()=>{btn.textContent='▶ শুনুন';btn.style.color='';btn.classList.remove('playing');},2500);
}

function toggleSurahAudio(){
  const audio=document.getElementById('surah-audio');
  const btn=document.getElementById('surah-play-btn');
  if(surahPlaying){audio.pause();surahPlaying=false;btn.textContent='▶';}
  else{
    stopAllAudio();
    const rec=document.getElementById('reciter-select').value;
    btn.textContent='⏳';
    audio.src=getSurahAudioUrl(curSurahNum,rec);
    audio.load();
    audio.play().then(()=>{surahPlaying=true;btn.textContent='⏸';}).catch(()=>{btn.textContent='❌';setTimeout(()=>btn.textContent='▶',2000);});
  }
}
function onSurahEnded(){surahPlaying=false;document.getElementById('surah-play-btn').textContent='▶';}
function changeReciter(){if(surahPlaying){surahPlaying=false;document.getElementById('surah-play-btn').textContent='▶';document.getElementById('surah-audio').pause();setTimeout(toggleSurahAudio,100);}}

let curAyahBtn=null;
function playAyah(surahNum,ayahNum,globalNum){
  const audio=document.getElementById('ayah-audio');
  const btn=document.getElementById('aybtn-'+ayahNum);
  if(curAyahBtn&&curAyahBtn!==btn){curAyahBtn.textContent='▶ শুনুন';curAyahBtn.classList.remove('playing');}
  if(btn.classList.contains('playing')){audio.pause();btn.textContent='▶ শুনুন';btn.classList.remove('playing');curAyahBtn=null;}
  else{
    stopSurahAudio();
    const rec=document.getElementById('reciter-select').value;
    btn.textContent='⏳';btn.classList.add('playing');curAyahBtn=btn;
    audio.src=getAyahAudioUrl(globalNum,rec);
    audio.load();
    audio.play().then(()=>{btn.textContent='⏸ চলছে';}).catch(()=>{showAudioError(btn);curAyahBtn=null;});
  }
}
function onAyahEnded(){if(curAyahBtn){curAyahBtn.textContent='▶ শুনুন';curAyahBtn.classList.remove('playing');curAyahBtn=null;}}
function stopSurahAudio(){document.getElementById('surah-audio').pause();surahPlaying=false;const b=document.getElementById('surah-play-btn');if(b)b.textContent='▶';}
function stopAllAudio(){
  stopSurahAudio();
  document.getElementById('ayah-audio').pause();
  if(curAyahBtn){curAyahBtn.textContent='▶ শুনুন';curAyahBtn.classList.remove('playing');curAyahBtn=null;}
  if(window.speechSynthesis)window.speechSynthesis.cancel();
}
