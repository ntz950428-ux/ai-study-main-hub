<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#0f2d26">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="নূর">
<title>নূর — ইসলামিক অ্যাপ</title>
<link rel="manifest" href="data:application/json,{%22name%22:%22%E0%A6%A8%E0%A7%82%E0%A6%B0%22,%22short_name%22:%22%E0%A6%A8%E0%A7%82%E0%A6%B0%22,%22display%22:%22standalone%22,%22background_color%22:%22%23f9f5ef%22,%22theme_color%22:%22%230f2d26%22}">
<link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Hind+Siliguri:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--teal:#1a6b5a;--teal2:#22897a;--gold:#c8993a;--gold2:#e8ba5a;--cream:#f9f5ef;--dark:#0f2d26;--text:#1e3d35;--muted:#6b8f87;--card:#fff;--shadow:0 4px 24px rgba(26,107,90,.10);}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{font-family:'Hind Siliguri',sans-serif;background:var(--cream);color:var(--text);min-height:100vh;max-width:480px;margin:0 auto;}

/* HEADER */
header{background:linear-gradient(135deg,var(--dark) 0%,var(--teal) 100%);padding:16px 16px 0;text-align:center;}
.bismillah{font-family:'Amiri',serif;font-size:1.4rem;color:rgba(255,255,255,.85);direction:rtl;}
.app-title{font-family:'Amiri',serif;font-size:2rem;color:var(--gold2);letter-spacing:2px;}
.app-subtitle{font-size:.8rem;color:rgba(255,255,255,.55);margin-top:1px;}

/* INSTALL BANNER */
#install-banner{display:none;background:linear-gradient(135deg,var(--gold) 0%,var(--gold2) 100%);padding:10px 16px;align-items:center;gap:10px;cursor:pointer;}
#install-banner.show{display:flex;}
.install-icon{font-size:1.4rem;}
.install-text{flex:1;font-size:.82rem;font-weight:600;color:var(--dark);}
.install-text small{display:block;font-weight:400;font-size:.75rem;opacity:.8;}
.install-close{background:rgba(0,0,0,.15);border:none;color:var(--dark);width:24px;height:24px;border-radius:50%;cursor:pointer;font-size:.9rem;}

/* NAV */
nav{display:flex;background:var(--dark);border-top:1px solid rgba(200,153,58,.2);overflow-x:auto;}
nav::-webkit-scrollbar{display:none;}
nav button{flex:1;min-width:60px;padding:10px 4px;background:none;border:none;color:rgba(255,255,255,.45);font-family:'Hind Siliguri',sans-serif;font-size:.72rem;cursor:pointer;border-bottom:3px solid transparent;white-space:nowrap;}
nav button.active{color:var(--gold2);border-bottom:3px solid var(--gold);}
nav button .icon{display:block;font-size:1.2rem;margin-bottom:1px;}

main{padding:14px;}
.tab-content{display:none;}
.tab-content.active{display:block;}

/* CARDS */
.date-card{background:linear-gradient(135deg,var(--teal) 0%,var(--teal2) 100%);border-radius:16px;padding:14px 18px;color:#fff;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center;box-shadow:var(--shadow);}
.date-card .hijri{font-family:'Amiri',serif;font-size:1.05rem;}
.date-card .gregorian{font-size:.78rem;opacity:.7;margin-top:2px;}
.date-card .loc{text-align:right;font-size:.78rem;opacity:.8;}

.prayer-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:14px;}
.prayer-card{background:var(--card);border-radius:13px;padding:13px 14px;box-shadow:var(--shadow);display:flex;align-items:center;gap:10px;}
.prayer-card.next{background:linear-gradient(135deg,var(--gold) 0%,var(--gold2) 100%);}
.prayer-card.next .pname,.prayer-card.next .ptime{color:#fff;}
.picon{font-size:1.5rem;}
.pname{font-size:.78rem;color:var(--muted);font-weight:500;}
.ptime{font-size:1.1rem;font-weight:700;color:var(--dark);}

.loc-btn{width:100%;padding:11px;background:#fff;border:2px dashed var(--teal2);border-radius:11px;color:var(--teal);font-family:'Hind Siliguri',sans-serif;font-size:.88rem;cursor:pointer;margin-bottom:14px;}

/* LOADING */
.loading{text-align:center;padding:26px;color:var(--muted);font-size:.88rem;}
.spinner{width:28px;height:28px;border:3px solid #e0ede9;border-top:3px solid var(--teal);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 8px;}
@keyframes spin{to{transform:rotate(360deg);}}

/* QURAN */
.surah-search{width:100%;padding:11px 14px;border:2px solid #e0ede9;border-radius:11px;font-family:'Hind Siliguri',sans-serif;font-size:.92rem;margin-bottom:12px;outline:none;background:#fff;}
.surah-search:focus{border-color:var(--teal2);}
.surah-list{display:flex;flex-direction:column;gap:7px;}
.surah-item{background:#fff;border-radius:11px;padding:11px 14px;display:flex;align-items:center;gap:12px;box-shadow:var(--shadow);cursor:pointer;}
.snum{width:34px;height:34px;background:var(--teal);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.78rem;font-weight:700;flex-shrink:0;}
.sinfo{flex:1;}
.sbn{font-size:.88rem;font-weight:600;}
.sar{font-family:'Amiri',serif;font-size:.95rem;color:var(--gold);direction:rtl;}
.smeta{font-size:.72rem;color:var(--muted);}

.quran-reader{display:none;}
.quran-reader.active{display:block;}
.reader-header{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.back-btn{background:none;border:none;font-size:1.3rem;cursor:pointer;color:var(--teal);padding:4px;}

/* AUDIO BAR */
.audio-bar{background:linear-gradient(135deg,var(--dark) 0%,var(--teal) 100%);border-radius:13px;padding:12px 14px;margin-bottom:12px;display:flex;align-items:center;gap:10px;box-shadow:var(--shadow);}
.aplay-btn{width:42px;height:42px;border-radius:50%;background:var(--gold);border:none;color:#fff;font-size:1.1rem;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.ainfo{flex:1;color:#fff;}
.atitle{font-size:.82rem;font-weight:600;}
.asub{font-size:.72rem;opacity:.65;margin-top:1px;}
.reciter-sel{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);color:#fff;border-radius:7px;padding:3px 6px;font-size:.72rem;font-family:'Hind Siliguri',sans-serif;cursor:pointer;}
.reciter-sel option{background:var(--dark);}

.ayah-card{background:#fff;border-radius:13px;padding:14px;margin-bottom:9px;box-shadow:var(--shadow);}
.ayah-ar{font-family:'Amiri',serif;font-size:1.45rem;direction:rtl;text-align:right;line-height:2.1;color:var(--dark);border-bottom:1px solid #eef4f2;padding-bottom:9px;margin-bottom:9px;}
.ayah-bn{font-size:.85rem;color:var(--text);line-height:1.7;}
.ayah-foot{display:flex;justify-content:space-between;align-items:center;margin-top:7px;}
.ayah-num{font-size:.72rem;color:var(--muted);}
.ayah-abtn{background:none;border:1px solid var(--teal2);border-radius:7px;padding:3px 9px;color:var(--teal);font-size:.72rem;cursor:pointer;}
.ayah-abtn.playing{background:var(--teal);color:#fff;}

/* HADITH */
.hadith-hdr{background:linear-gradient(135deg,var(--dark) 0%,var(--teal) 100%);border-radius:15px;padding:18px;color:#fff;text-align:center;margin-bottom:14px;box-shadow:var(--shadow);}
.hadith-hdr .lbl{font-size:.78rem;opacity:.65;letter-spacing:1px;}
.hadith-hdr h2{font-family:'Amiri',serif;font-size:1.3rem;margin-top:3px;}
.hadith-card{background:#fff;border-radius:15px;padding:18px;box-shadow:var(--shadow);margin-bottom:10px;border-left:4px solid var(--gold);}
.hadith-ar{font-family:'Amiri',serif;font-size:1.15rem;direction:rtl;text-align:right;line-height:1.9;color:var(--dark);margin-bottom:10px;}
.hadith-bn{font-size:.88rem;line-height:1.8;color:var(--text);margin-bottom:10px;}
.hadith-src{font-size:.75rem;color:var(--muted);background:var(--cream);padding:5px 10px;border-radius:7px;display:inline-block;}
.hadith-actions{display:flex;gap:9px;margin-top:10px;}
.h-audio-btn{flex:1;padding:10px;background:linear-gradient(135deg,var(--teal) 0%,var(--teal2) 100%);color:#fff;border:none;border-radius:10px;font-family:'Hind Siliguri',sans-serif;font-size:.88rem;cursor:pointer;}
.h-audio-btn.playing{background:linear-gradient(135deg,#c0392b 0%,#e74c3c 100%);}
.h-next-btn{flex:1;padding:10px;background:#fff;border:2px solid var(--teal2);color:var(--teal);border-radius:10px;font-family:'Hind Siliguri',sans-serif;font-size:.88rem;cursor:pointer;}

/* TASBIH */
.tasbih-wrap{display:flex;flex-direction:column;align-items:center;padding:10px 0;}
.tasbih-mode-btns{display:flex;gap:8px;margin-bottom:20px;width:100%;}
.tmode-btn{flex:1;padding:9px;border-radius:10px;border:2px solid var(--teal2);background:#fff;color:var(--teal);font-family:'Hind Siliguri',sans-serif;font-size:.85rem;cursor:pointer;font-weight:600;}
.tmode-btn.active{background:var(--teal);color:#fff;border-color:var(--teal);}
.tasbih-circle{width:200px;height:200px;border-radius:50%;background:linear-gradient(135deg,var(--dark) 0%,var(--teal) 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;box-shadow:0 8px 32px rgba(26,107,90,.3);cursor:pointer;user-select:none;margin-bottom:18px;transition:transform .1s;}
.tasbih-circle:active{transform:scale(.96);}
.tasbih-count{font-size:3.5rem;font-weight:700;color:#fff;line-height:1;}
.tasbih-total{font-size:.85rem;color:rgba(255,255,255,.65);margin-top:4px;}
.tasbih-zikr{font-family:'Amiri',serif;font-size:1.2rem;color:var(--gold2);margin-top:6px;direction:rtl;}
.tasbih-progress{width:200px;height:8px;background:rgba(255,255,255,.2);border-radius:4px;margin-bottom:18px;overflow:hidden;}
.tasbih-bar{height:100%;background:var(--gold2);border-radius:4px;transition:width .2s;}
.tasbih-btns{display:flex;gap:10px;}
.t-reset-btn{padding:11px 24px;background:#fff;border:2px solid #e0e0e0;border-radius:10px;font-family:'Hind Siliguri',sans-serif;font-size:.88rem;cursor:pointer;color:var(--muted);}
.t-vibrate-badge{font-size:.72rem;color:var(--muted);margin-top:8px;}

/* DOWA */
.dowa-cats{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:14px;}
.dcat-btn{padding:6px 13px;border-radius:20px;border:1.5px solid var(--teal2);background:#fff;color:var(--teal);font-family:'Hind Siliguri',sans-serif;font-size:.8rem;cursor:pointer;}
.dcat-btn.active{background:var(--teal);color:#fff;border-color:var(--teal);}
.dowa-list{display:flex;flex-direction:column;gap:9px;}
.dowa-card{background:#fff;border-radius:13px;padding:16px;box-shadow:var(--shadow);border-top:3px solid var(--gold);}
.dowa-title{font-size:.85rem;font-weight:700;color:var(--teal);margin-bottom:8px;}
.dowa-ar{font-family:'Amiri',serif;font-size:1.2rem;direction:rtl;text-align:right;line-height:1.9;color:var(--dark);margin-bottom:8px;}
.dowa-bn{font-size:.83rem;line-height:1.7;color:var(--text);margin-bottom:6px;}
.dowa-src{font-size:.72rem;color:var(--muted);}
.dowa-abtn{margin-top:8px;padding:5px 12px;background:none;border:1px solid var(--teal2);border-radius:7px;color:var(--teal);font-size:.75rem;cursor:pointer;font-family:'Hind Siliguri',sans-serif;}
.dowa-abtn.playing{background:var(--teal);color:#fff;}

/* QIBLA */
.qibla-wrap{text-align:center;padding:10px 0;}
.qibla-compass{width:220px;height:220px;margin:0 auto 16px;position:relative;}
.compass-outer{width:220px;height:220px;border-radius:50%;background:linear-gradient(135deg,var(--dark) 0%,var(--teal) 100%);display:flex;align-items:center;justify-content:center;box-shadow:0 8px 32px rgba(26,107,90,.3);}
.compass-inner{width:180px;height:180px;border-radius:50%;background:var(--cream);display:flex;align-items:center;justify-content:center;position:relative;}
.compass-arrow{font-size:3rem;transition:transform .5s ease;}
.compass-kaaba{font-size:1.4rem;position:absolute;}
.qibla-degree{font-size:1.4rem;font-weight:700;color:var(--teal);margin-bottom:4px;}
.qibla-info{font-size:.85rem;color:var(--muted);margin-bottom:18px;}
.qibla-get-btn{padding:12px 28px;background:linear-gradient(135deg,var(--teal) 0%,var(--teal2) 100%);color:#fff;border:none;border-radius:11px;font-family:'Hind Siliguri',sans-serif;font-size:.92rem;cursor:pointer;}
.qibla-note{font-size:.78rem;color:var(--muted);margin-top:12px;line-height:1.6;}

/* RAMADAN */
.ramadan-hdr{background:linear-gradient(135deg,var(--dark) 0%,#1a3a5c 100%);border-radius:15px;padding:18px;color:#fff;text-align:center;margin-bottom:14px;box-shadow:var(--shadow);}
.ramadan-hdr h2{font-family:'Amiri',serif;font-size:1.4rem;}
.ramadan-hdr p{font-size:.8rem;opacity:.7;margin-top:4px;}
.ramadan-day{background:#fff;border-radius:12px;padding:13px 16px;margin-bottom:8px;box-shadow:var(--shadow);display:flex;align-items:center;gap:14px;}
.ramadan-day.today{border:2px solid var(--gold);background:linear-gradient(135deg,rgba(200,153,58,.05) 0%,rgba(232,186,90,.08) 100%);}
.rday-num{width:38px;height:38px;border-radius:50%;background:var(--teal);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.88rem;flex-shrink:0;}
.ramadan-day.today .rday-num{background:var(--gold);}
.rday-info{flex:1;}
.rday-bn{font-size:.82rem;font-weight:600;}
.rday-times{font-size:.75rem;color:var(--muted);margin-top:2px;}
.rday-badge{font-size:.7rem;background:var(--gold);color:var(--dark);padding:2px 8px;border-radius:10px;font-weight:600;}

.ornament{text-align:center;color:var(--gold);font-size:1.1rem;margin:10px 0;letter-spacing:5px;}
</style>
</head>
<body>

<header>
  <div class="bismillah">بِسْمِ اللهِ الرَّحْمٰنِ الرَّحِيْمِ</div>
  <div class="app-title">نور · নূর</div>
  <div class="app-subtitle">আলোর পথে চলো</div>
</header>

<!-- INSTALL BANNER -->
<div id="install-banner">
  <span class="install-icon">📲</span>
  <div class="install-text">হোম স্ক্রিনে যোগ করুন <small>অ্যাপের মতো ব্যবহার করুন — অফলাইনেও চলবে</small></div>
  <button class="install-close" onclick="dismissInstall()">✕</button>
</div>

<nav>
  <button class="active" onclick="switchTab('prayer',this)"><span class="icon">🕌</span>নামাজ</button>
  <button onclick="switchTab('quran',this)"><span class="icon">📖</span>কোরআন</button>
  <button onclick="switchTab('hadith',this)"><span class="icon">☀️</span>হাদিস</button>
  <button onclick="switchTab('tasbih',this)"><span class="icon">📿</span>তাসবিহ</button>
  <button onclick="switchTab('dowa',this)"><span class="icon">🤲</span>দোয়া</button>
  <button onclick="switchTab('qibla',this)"><span class="icon">🧭</span>কিবলা</button>
  <button onclick="switchTab('ramadan',this)"><span class="icon">🌙</span>রমজান</button>
</nav>

<main>

<!-- ========== PRAYER ========== -->
<div id="tab-prayer" class="tab-content active">
  <div class="date-card">
    <div><div class="hijri" id="hijri-date">লোড হচ্ছে...</div><div class="gregorian" id="greg-date"></div></div>
    <div class="loc" id="location-text">📍 ঢাকা</div>
  </div>
  <button class="loc-btn" id="loc-btn" onclick="getLocation()">📍 আমার লোকেশন থেকে সময় দেখাও</button>
  <div id="prayer-loading" class="loading" style="display:none"><div class="spinner"></div>লোকেশন খুঁজছি...</div>
  <div class="prayer-grid">
    <div class="prayer-card" id="card-fajr"><span class="picon">🌄</span><div><div class="pname">ফজর</div><div class="ptime" id="t-fajr">--:--</div></div></div>
    <div class="prayer-card" id="card-dhuhr"><span class="picon">☀️</span><div><div class="pname">যোহর</div><div class="ptime" id="t-dhuhr">--:--</div></div></div>
    <div class="prayer-card" id="card-asr"><span class="picon">🌤️</span><div><div class="pname">আসর</div><div class="ptime" id="t-asr">--:--</div></div></div>
    <div class="prayer-card" id="card-maghrib"><span class="picon">🌇</span><div><div class="pname">মাগরিব</div><div class="ptime" id="t-maghrib">--:--</div></div></div>
    <div class="prayer-card" id="card-isha" style="grid-column:span 2"><span class="picon">🌙</span><div><div class="pname">এশা</div><div class="ptime" id="t-isha">--:--</div></div></div>
  </div>
</div>

<!-- ========== QURAN ========== -->
<div id="tab-quran" class="tab-content">
  <div id="surah-list-view">
    <input class="surah-search" type="text" placeholder="সূরা খুঁজুন..." id="surah-search" oninput="filterSurahs()">
    <div class="surah-list" id="surah-list"></div>
  </div>
  <div id="quran-reader" class="quran-reader">
    <div class="reader-header">
      <button class="back-btn" onclick="backToList()">←</button>
      <div><div id="reader-surah-name" style="font-weight:700;font-size:.95rem;"></div><div id="reader-surah-ar" style="font-family:'Amiri',serif;color:var(--gold);direction:rtl;font-size:.95rem;"></div></div>
    </div>
    <div class="audio-bar">
      <button class="aplay-btn" id="surah-play-btn" onclick="toggleSurahAudio()">▶</button>
      <div class="ainfo"><div class="atitle" id="audio-title">সম্পূর্ণ সূরা শুনুন</div><div class="asub">তেলাওয়াত · আরবি</div></div>
      <select class="reciter-sel" id="reciter-select" onchange="changeReciter()">
        <option value="7">মিশারি</option>
        <option value="1">আব্দুল বাসিত</option>
        <option value="3">আবু বকর</option>
      </select>
    </div>
    <div class="ornament">❧ ✦ ❧</div>
    <div id="ayah-list"></div>
  </div>
</div>

<!-- ========== HADITH ========== -->
<div id="tab-hadith" class="tab-content">
  <div class="hadith-hdr"><div class="lbl">আজকের হাদিস</div><h2>রাসুলুল্লাহ ﷺ বলেছেন</h2></div>
  <div id="hadith-display"></div>
  <div class="hadith-actions">
    <button class="h-audio-btn" id="hadith-audio-btn" onclick="toggleHadithAudio()">🔊 বাংলায় শুনুন</button>
    <button class="h-next-btn" onclick="nextHadith()">পরবর্তী →</button>
  </div>
</div>

<!-- ========== TASBIH ========== -->
<div id="tab-tasbih" class="tab-content">
  <div class="tasbih-wrap">
    <div class="tasbih-mode-btns">
      <button class="tmode-btn active" onclick="setTasbihMode(33,this,'سُبْحَانَ اللهِ','সুবহানাল্লাহ')">৩৩ বার<br><small>সুবহানাল্লাহ</small></button>
      <button class="tmode-btn" onclick="setTasbihMode(33,this,'اَلْحَمْدُ لِلَّه','আলহামদুলিল্লাহ')">৩৩ বার<br><small>আলহামদুলিল্লাহ</small></button>
      <button class="tmode-btn" onclick="setTasbihMode(33,this,'اللهُ أَكْبَر','আল্লাহু আকবার')">৩৩ বার<br><small>আল্লাহু আকবার</small></button>
      <button class="tmode-btn" onclick="setTasbihMode(99,this,'لَا إِلٰهَ إِلَّا اللهُ','লা ইলাহা ইল্লাল্লাহ')">৯৯ বার<br><small>লা ইলাহা...</small></button>
    </div>
    <div class="tasbih-circle" onclick="tapTasbih()" id="tasbih-circle">
      <div class="tasbih-count" id="tasbih-count">0</div>
      <div class="tasbih-total" id="tasbih-total">/ 33</div>
      <div class="tasbih-zikr" id="tasbih-zikr">سُبْحَانَ اللهِ</div>
    </div>
    <div class="tasbih-progress"><div class="tasbih-bar" id="tasbih-bar" style="width:0%"></div></div>
