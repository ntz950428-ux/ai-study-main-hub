// ===== HADITH =====
const hadiths=[
  {arabic:'إِنَّمَا الأَعْمَالُ بِالنِّيَّاتِ',bengali:'নিশ্চয়ই সমস্ত কাজ নিয়তের উপর নির্ভর করে এবং প্রত্যেক ব্যক্তি তাই পাবে যা সে নিয়ত করেছে।',source:'সহীহ বুখারী: ১'},
  {arabic:'الْمُسْلِمُ مَنْ سَلِمَ الْمُسْلِمُونَ مِنْ لِسَانِهِ وَيَدِهِ',bengali:'মুসলমান সে ব্যক্তি যার জিহ্বা ও হাত থেকে অন্য মুসলমান নিরাপদ থাকে।',source:'সহীহ বুখারী: ১০'},
  {arabic:'لاَ يُؤْمِنُ أَحَدُكُمْ حَتَّى يُحِبَّ لأَخِيهِ مَا يُحِبُّ لِنَفْسِهِ',bengali:'তোমাদের কেউ ততক্ষণ মুমিন হতে পারবে না যতক্ষণ না সে তার ভাইয়ের জন্য তাই পছন্দ করবে যা সে নিজের জন্য পছন্দ করে।',source:'সহীহ বুখারী: ১৩'},
  {arabic:'مَنْ كَانَ يُؤْمِنُ بِاللَّهِ فَلْيَقُلْ خَيْرًا أَوْ لِيَصْمُتْ',bengali:'যে ব্যক্তি আল্লাহ ও আখিরাতের দিনের উপর ইমান রাখে, সে যেন ভালো কথা বলে অথবা চুপ থাকে।',source:'সহীহ বুখারী: ৬০১৮'},
  {arabic:'الطَّهُورُ شَطْرُ الإِيمَانِ',bengali:'পবিত্রতা ইমানের অর্ধেক।',source:'সহীহ মুসলিম: ২২৩'},
  {arabic:'خَيْرُكُمْ مَنْ تَعَلَّمَ الْقُرْآنَ وَعَلَّمَهُ',bengali:'তোমাদের মধ্যে সর্বোত্তম সে ব্যক্তি যে কুরআন শেখে এবং অন্যকে শেখায়।',source:'সহীহ বুখারী: ৫০২৭'},
  {arabic:'الدِّينُ النَّصِيحَةُ',bengali:'দ্বীন হলো কল্যাণকামিতা।',source:'সহীহ মুসলিম: ৫৫'},
];
let hadithIdx=new Date().getDate()%hadiths.length,hadithSpeaking=false;
function renderHadith(){
  const h=hadiths[hadithIdx];
  document.getElementById('hadith-display').innerHTML=`<div class="hadith-card"><div class="hadith-ar">${h.arabic}</div><div class="hadith-bn">${h.bengali}</div><span class="hadith-src">📚 ${h.source}</span></div>`;
  const b=document.getElementById('hadith-audio-btn');
  if(b){b.textContent='🔊 বাংলায় শুনুন';b.classList.remove('playing');hadithSpeaking=false;}
}
function nextHadith(){stopHadithAudio();hadithIdx=(hadithIdx+1)%hadiths.length;renderHadith();}
function toggleHadithAudio(){
  const btn=document.getElementById('hadith-audio-btn');
  if(hadithSpeaking){stopHadithAudio();}
  else{
    if(!window.speechSynthesis){alert('এই ব্রাউজারে সাপোর্ট নেই।');return;}
    window.speechSynthesis.cancel();
    const u=new SpeechSynthesisUtterance(hadiths[hadithIdx].bengali);
    u.lang='bn-BD';u.rate=0.88;
    u.onend=()=>{hadithSpeaking=false;btn.textContent='🔊 বাংলায় শুনুন';btn.classList.remove('playing');};
    window.speechSynthesis.speak(u);
    hadithSpeaking=true;btn.textContent='⏹ থামাও';btn.classList.add('playing');
  }
}
function stopHadithAudio(){if(window.speechSynthesis)window.speechSynthesis.cancel();hadithSpeaking=false;const b=document.getElementById('hadith-audio-btn');if(b){b.textContent='🔊 বাংলায় শুনুন';b.classList.remove('playing');}}
